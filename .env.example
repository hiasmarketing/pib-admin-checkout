# Supabase — projeto PIB
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=eyJ...

# Public domains
NEXT_PUBLIC_CHECKOUT_URL=https://checkout.faria-castro.com.br
NEXT_PUBLIC_ADMIN_URL=https://admin.faria-castro.com.br
NEXT_PUBLIC_SITE_URL=https://checkout.faria-castro.com.br

# Checkout
# TEMPORARY - remove once all links use turma/product from admin catalog
CHECKOUT_UNIT_AMOUNT_CENTS=349700

# Admin / Jobs — 32 byte hex (openssl rand -hex 32). Mesmo valor em vault.secrets.pib_admin_job_secret
ADMIN_JOB_SECRET=replace-with-a-random-secret

# Outbound Webhooks — 32 byte hex (openssl rand -hex 32). Encripta secret_encrypted em outbound_webhook_endpoints
OUTBOUND_WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# pagar.me — Checkout BRL
# Dashboard: https://dashboard.pagar.me/
PAGARME_SECRET_KEY=sk_test_...
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=pk_test_...
# Sandbox: https://sdx-api.pagar.me/core/v5  |  Produção: https://api.pagar.me/core/v5
PAGARME_BASE_URL=https://sdx-api.pagar.me/core/v5
PAGARME_WEBHOOK_SECRET=replace-with-webhook-secret
