# Public domains
NEXT_PUBLIC_CHECKOUT_URL=https://checkout.metododestiny.com.br
NEXT_PUBLIC_ADMIN_URL=https://admin.metododestiny.com.br
NEXT_PUBLIC_SITE_URL=https://checkout.metododestiny.com.br

# Checkout
# TEMPORARY - remove once all links use turma/product from admin catalog
CHECKOUT_UNIT_AMOUNT_CENTS=349700

# Admin / Jobs
ADMIN_JOB_SECRET=replace-with-a-random-secret

# Outbound Webhooks
OUTBOUND_WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# pagar.me - Checkout BRL
# Dashboard: https://dashboard.pagar.me/
PAGARME_SECRET_KEY=sk_live_...
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=pk_live_...
PAGARME_BASE_URL=https://api.pagar.me/core/v5
# Produção: PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_WEBHOOK_SECRET=replace-with-webhook-secret

# Conversao USD -> BRL
# Fonte: https://economia.awesomeapi.com.br/json/last/USD-BRL (campo bid)
# Usado como fallback se a API externa estiver indisponível.
USD_BRL_FALLBACK_RATE=5.80
